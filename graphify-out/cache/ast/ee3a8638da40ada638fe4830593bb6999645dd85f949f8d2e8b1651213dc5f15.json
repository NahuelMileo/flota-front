 justify-between border-t pt-2\">\n                  <span className=\"text-muted-foreground\">Ingreso/km:</span>\n                  <span className=\"font-medium text-green-600\">\n                    {fmtMoney2(trip.totalIncome / tripKm)}\n                  </span>\n                </div>\n              ) : null;\n            })", "is_member_call": false, "source_file": "/Users/nahuelmileo/Desktop/paginas/flota/app/(dashboard)/trips/[id]/page.tsx", "source_location": "L375"}, {"caller_nid": "id_page_tripdetailpage", "callee": "map", "is_member_call": true, "source_file": "/Users/nahuelmileo/Desktop/paginas/flota/app/(dashboard)/trips/[id]/page.tsx", "source_location": "L406"}, {"caller_nid": "id_page_tripdetailpage", "callee": "map", "is_member_call": true, "source_file": "/Users/nahuelmileo/Desktop/paginas/flota/app/(dashboard)/trips/[id]/page.tsx", "source_location": "L439"}, {"caller_nid": "id_page_tripdetailpage", "callee": "(() => {\n        const breakdown = trip.expenses.reduce<Record<string, number>>((acc, e) => {\n          const key = e.categoryName ?? \"Sin categor\u00eda\"\n          acc[key] = (acc[key] ?? 0) + getDisplayValue(e);\n          return acc;\n        }, {});\n        const sorted = Object.entries(breakdown).sort(([, a], [, b]) => b - a);\n        return (\n          <div className=\"rounded-lg border p-4 space-y-3\">\n            <h3 className=\"font-semibold\">Egresos por categor\u00eda</h3>\n            <div className=\"space-y-2 text-sm\">\n              {sorted.map(([categoryName, total]) => (\n                <div key={categoryName} className=\"flex justify-between items-center\">\n                  <span className=\"text-muted-foreground\">{categoryName}</span>\n                  <div className=\"flex items-center gap-3\">\n                    <span className=\"text-xs text-muted-foreground\">\n                      {Math.round((total / trip.totalExpense) * 100)}%\n                    </span>\n                    <span className=\"font-medium text-red-600 w-28 text-right\">\n                      {fmtMoney(total)}\n                    </span>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        );\n      })", "is_member_call": false, "source_file": "/Users/nahuelmileo/Desktop/paginas/flota/app/(dashboard)/trips/[id]/page.tsx", "source_location": "L465"}]}